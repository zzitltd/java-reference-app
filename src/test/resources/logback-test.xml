<?xml version="1.0" encoding="UTF-8"?>
<!-- Test logging: Spring Boot's console layout, with one noisy bootstrap logger quieted. -->
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>
    <include resource="org/springframework/boot/logging/logback/console-appender.xml"/>

    <!-- "Could not detect default configuration classes for test class …" — benign: @SpringBootTest
         falls back to the @SpringBootConfiguration main class, which is exactly what we want. -->
    <logger name="org.springframework.test.context.support.AnnotationConfigContextLoaderUtils" level="WARN"/>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>
</configuration>
